# ============================================================
# SoaLatihan — Environment Variables
# Copy this file to ".env" and fill in real values.
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Application Port
# Public/local port the app listens on.
# Change this to deploy on a different port:
#   APP_PORT=8080 docker compose up -d
#   APP_PORT=8080 npm start
# ----------------------------------------------------------
APP_PORT=3000

# ----------------------------------------------------------
# Database — PostgreSQL
# Used by Prisma, Docker Compose, and deploy scripts.
#
# Docker Compose: the app connects to service "db" on port 5432.
# Native / local dev: change host from "db" to "localhost".
# ----------------------------------------------------------
DATABASE_URL=postgresql://soalatihan:change-this-password@db:5432/soalatihan

# PostgreSQL container credentials (used by docker-compose.yml)
POSTGRES_USER=soalatihan
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=soalatihan

# ----------------------------------------------------------
# NextAuth.js (Auth.js v5)
# ----------------------------------------------------------
# Random 32+ character string used for signing JWT tokens.
# Generate one with:
#   openssl rand -base64 32
# Also used as the master key for AES-256-GCM encryption
# of sensitive AppConfig values (e.g. ai_api_key).
NEXTAUTH_SECRET=generate-a-random-32-char-string-here

# Public URL of the deployment.
# Examples:
#   http://localhost:3000
#   https://soalatihan.example.com
NEXTAUTH_URL=http://localhost:3000

# ----------------------------------------------------------
# Node Environment (do not change for production)
# ----------------------------------------------------------
NODE_ENV=production
